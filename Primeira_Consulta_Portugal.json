{
    "version": "7.3",
    "data_api_version": "3.0",
    "routing_model": {
        "primeira_tela": ["segunda_tela", "quarta_tela"],
        "segunda_tela": [],
        "terceira_tela": [],
        "quarta_tela": ["quinta_tela"],
        "quinta_tela": ["terceira_tela"]
    },
    "screens": [
        {
            "id": "primeira_tela",
            "title": "Primeira consulta",
            "terminal": false,
            "layout": {
                "type": "SingleColumnLayout",
                "children": [
                    {
                        "type": "Form",
                        "name": "clinica_form",
                        "children": [
                            {
                                "type": "TextSubheading",
                                "text": "Perfeito! Qual a clínica que fica mais conveniente para si?"
                            },
                            {
                                "type": "RadioButtonsGroup",
                                "name": "clinica",
                                "required": true,
                                "label": "Selecione uma das opções abaixo",
                                "data-source": [
                                    {
                                        "id": "braga",
                                        "title": "BRAGA",
                                        "description": "Rua Drº, R. Dr. Egídio Guimarães nº78, 4715-031 Braga"
                                    },
                                    {
                                        "id": "lisboa",
                                        "title": "LISBOA",
                                        "description": "Av. Dom João II 42 5º andar, 1990-095 Lisboa"
                                    },
                                    {
                                        "id": "porto",
                                        "title": "PORTO",
                                        "description": "Av. de Montevideu 66, 4150-516 Porto"
                                    },
                                    {
                                        "id": "vilamoura",
                                        "title": "VILAMOURA",
                                        "description": "Urbanização Vila Sol Rua 1 Lote b34, 8125-303 Quarteira"
                                    },
                                    {
                                        "id": "viseu",
                                        "title": "VISEU",
                                        "description": "R. do Palacio do Gelo 3 Lote 215, 3509-606 Viseu"
                                    },
                                    {
                                        "id": "nenhum",
                                        "title": "Nenhuma disponível",
                                        "description": "Não consigo comparecer em nenhuma das clínicas listadas."
                                    }
                                ]
                            },
                            {
                                "type": "If",
                                "condition": "${form.clinica} == 'nenhum'",
                                "then": [
                                    {
                                    "type": "Footer",
                                        "label": "Continuar",
                                        "on-click-action": {
                                            "name": "navigate",
                                            "next": {
                                                "type": "screen",
                                                "name": "quarta_tela"
                                            }
                                        } 
                                    }
                                ],
                                "else": [
                                    {
                                        "type": "Footer",
                                        "label": "Continuar",
                                        "on-click-action": {
                                            "name": "navigate",
                                            "next": {
                                                "type": "screen",
                                                "name": "segunda_tela"
                                            }
                                        }
                                    }
                                ]
                            }
                        ]
                    }
                ]
            }
        },
        {
            "id": "quarta_tela",
            "title": "Primeira consulta",
            "terminal": true,
            "layout": {
                "type": "SingleColumnLayout",
                "children": [
                    {
                        "type": "Form",
                        "name": "consulta_online",
                        "children": [
                            {
                                "type": "TextSubheading",
                                "text": "Para avançarmos, precisamos de compreender a sua preferência."
                            },
                            {
                                "type": "RadioButtonsGroup",
                                "name": "consulta_online",
                                "required": true,
                                "label": "Pretende agendar uma consulta online?",
                                "data-source": [
                                    {
                                        "id": "sim",
                                        "title": "Sim"
                                    },
                                    {
                                        "id": "nao",
                                        "title": "Não"
                                    }
                                ]
                            },
                            {
                                "type": "If",
                                "condition":"${form.consulta_online} == 'nao'",
                                "then": [
                                    {
                                        "type": "TextBody",
                                        "text": "Compreendemos. Se mudar de ideias ou precisar de ajuda, pode voltar a falar connosco a qualquer momento. 😊"
                                    }
                                ]
                            },
                            {
                                "type": "If",
                                "condition": "${form.consulta_online} == 'sim'",
                                "then": [
                                    {
                                    "type": "Footer",
                                        "label": "Continuar",
                                        "on-click-action": {
                                            "name": "data_exchange",
                                            "payload": {
                                                "screen": "quinta_tela"
                                            }
                                        } 
                                    }
                                ],
                                "else": [
                                    {
                                        "type": "Footer",
                                        "label": "Finalizar",
                                        "on-click-action": {
                                            "name": "complete",
                                            "payload": {}
                                        }
                                    }
                                ]
                            }
                        ]
                    }
                ]
            }
        },
        {
            "id": "segunda_tela",
            "title": "Primeira consulta",
            "terminal": true,
            "layout": {
                "type": "SingleColumnLayout",
                "children": [
                    {
                        "type": "Form",
                        "name": "dados_form",
                        "children": [
                            {
                                "type": "TextSubheading",
                                "text": "Para finalizar, pedimos que indique algumas informações pessoais."
                            },
                            {
                                "type": "TextBody",
                                "text": "O seu nome completo"
                            },
                            {
                                "type": "TextInput",
                                "label": "Nome completo",
                                "name": "nome",
                                "required": true
                            },
                            {
                                "type": "TextBody",
                                "text": "A sua data de nascimento"
                            },
                            {
                                "type": "DatePicker",
                                "label": "Data de nascimento",
                                "name": "data_nascimento",
                                "required": true,
                                "min-date": "1900-01-01",
                                "max-date": "2020-01-01"
                            },
                            {
                                "type": "TextBody",
                                "text": "O seu e-mail"
                            },
                            {
                                "type": "TextInput",
                                "label": "E-mail",
                                "name": "email",
                                "input-type": "email",
                                "required": true
                            },
                            {
                                "type": "Footer",
                                "label": "Enviar",
                                "on-click-action": {
                                    "name": "complete",
                                    "payload": {}
                                }
                            }
                        ]
                    }
                ]
            }
        },
        {
            "id": "quinta_tela",
            "title": "Primeira consulta",
            "terminal": false,
            "layout": {
                "type": "SingleColumnLayout",
                "children": [
                    {
                        "type": "Form",
                        "name": "dados_form",
                        "children": [
                            {
                                "type": "TextSubheading",
                                "text": "Para prosseguirmos, pedimos que indique algumas informações pessoais."
                            },
                            {
                                "type": "TextBody",
                                "text": "O seu nome completo"
                            },
                            {
                                "type": "TextInput",
                                "label": "Nome completo",
                                "name": "nome",
                                "required": true
                            },
                            {
                                "type": "TextBody",
                                "text": "A sua data de nascimento"
                            },
                            {
                                "type": "DatePicker",
                                "label": "Data de nascimento",
                                "name": "data_nascimento",
                                "required": true,
                                "min-date": "1900-01-01",
                                "max-date": "2020-01-01"
                            },
                            {
                                "type": "TextBody",
                                "text": "O seu e-mail"
                            },
                            {
                                "type": "TextInput",
                                "label": "E-mail",
                                "name": "email",
                                "input-type": "email",
                                "required": true
                            },
                            {
                                "type": "TextBody",
                                "text": "O seu género"
                            },
                            {
                                "type": "Dropdown",
                                "name": "genero",
                                "label": "Género",
                                "required": true,
                                "data-source": [
                                    {
                                        "id": "masculino",
                                        "title": "Masculino"
                                    },
                                    {
                                        "id": "feminino",
                                        "title": "Feminino"
                                    },
                                    {
                                        "id": "outro",
                                        "title": "Outro"
                                    }
                                ]
                            },
                            {
                                "type": "Footer",
                                "label": "Continuar",
                                "on-click-action": {
                                    "name": "data_exchange",
                                    "payload": {
                                        "screen": "terceira_tela"
                                    }
                                }
                            }
                        ]
                    }
                ]
            }
        },
        {
            "id": "terceira_tela",
            "title": "Primeira consulta",
            "terminal": true,
            "layout": {
                "type": "SingleColumnLayout",
                "children": [
                    {
                        "type": "Form",
                        "name": "procedimento_form",
                        "children": [
                            {
                                "type": "TextSubheading",
                                "text": "Para finalizar, indique a área de interesse."
                            },
                            {
                                "type": "Dropdown",
                                "name": "area",
                                "label": "Área",
                                "required": true,
                                "data-source": [
                                    {
                                        "id": "couro_cabeludo",
                                        "title": "Cabelo"
                                    },
                                    {
                                        "id": "barba",
                                        "title": "Barba"
                                    },
                                    {
                                        "id": "sobrancelhas",
                                        "title": "Sobrancelhas"
                                    }
                                ]
                            },
                            {
                                "type": "TextCaption",
                                "text": "Nota: O procedimento mais indicado será confirmado após avaliação clínica."
                            },
                            {
                                "type": "Footer",
                                "label": "Enviar",
                                "on-click-action": {
                                    "name": "complete",
                                    "payload": {}
                                }
                            }
                        ]
                    }
                ]
            }
        }
    ]
}